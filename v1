Instance.new("UICorner", AutoDummyBtn).CornerRadius = UDim.new(0,6)

local function getNextEnemy()
    local folder = workspace:FindFirstChild("Enemys")
    if not folder then return end

    for _, enemy in ipairs(folder:GetChildren()) do
        local hum = enemy:FindFirstChild("Humanoid")
        local hrpE = enemy:FindFirstChild("HumanoidRootPart")
        if hum and hum.Health > 0 and hrpE then
            return enemy, hum, hrpE
        end
    end
end

task.spawn(function()
    while true do
        if autoDummy and HRP then
            local enemy, hum, hrpE = getNextEnemy()
            if enemy then
                hrpE.Size = Vector3.new(40,40,40)
                hrpE.CanCollide = false

                local behind = hrpE.CFrame * CFrame.new(0,0,6)
                HRP.CFrame = CFrame.new(behind.Position, hrpE.Position)

                if hum.Health <= 0 then
                    task.wait(0.1)
                end
            end
        end
        task.wait(0.05)
    end
end)

