--========================================================
-- K TOGGLE (SAFE FIX)
--========================================================

UIS.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

	if input.KeyCode == Enum.KeyCode.K then
		autoK = not autoK

		if autoK then
			AutoKBtn.Text = "Auto K Toggle : ON (K toggle)"
			AutoKBtn.BackgroundColor3 = Color3.fromRGB(0,170,0)
		else
			AutoKBtn.Text = "Auto K Toggle : OFF (K toggle)"
			AutoKBtn.BackgroundColor3 = Color3.fromRGB(50,50,50)
		end
	end
end)

